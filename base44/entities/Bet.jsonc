{
  "name": "Bet",
  "type": "object",
  "properties": {
    "match_id": {
      "type": "string",
      "description": "Reference to Match entity"
    },
    "title": {
      "type": "string",
      "description": "Bet display title"
    },
    "outcome_a": {
      "type": "string",
      "description": "Label for outcome A (team name)"
    },
    "outcome_b": {
      "type": "string",
      "description": "Label for outcome B (team name)"
    },
    "open_until": {
      "type": "string",
      "format": "date-time",
      "description": "Betting closes at this time"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "settled",
        "void"
      ],
      "default": "open"
    },
    "winning_outcome": {
      "type": "string",
      "enum": [
        "a",
        "b",
        ""
      ],
      "default": "",
      "description": "Which outcome won after settlement"
    },
    "lp_amount_a": {
      "type": "number",
      "default": 0,
      "description": "Total liquidity provided backing outcome A (LP side)"
    },
    "lp_amount_b": {
      "type": "number",
      "default": 0,
      "description": "Total liquidity provided backing outcome B (LP side)"
    },
    "backed_amount_a": {
      "type": "number",
      "default": 0,
      "description": "Total bettor money placed ON outcome A"
    },
    "backed_amount_b": {
      "type": "number",
      "default": 0,
      "description": "Total bettor money placed ON outcome B"
    },
    "total_pool": {
      "type": "number",
      "default": 0,
      "description": "Total pool (all LP + bettors)"
    },
    "fee_percent": {
      "type": "number",
      "default": 200,
      "description": "Fee in basis points (200 = 2%)"
    },
    "total_bettors": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "match_id",
    "outcome_a",
    "outcome_b"
  ]
}